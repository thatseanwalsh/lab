  "systemd": {
    "units": [
      {
        "enabled": true,
        "name": "run-secrets.mount"
      },
      {
        "dropins": [
          {
            "contents": "[Unit]\n# Ensure firewalld starts before container-related units.\n# Use the generic containers target and podman.service instead\n# of listing individual services so new container units are\n# covered automatically.\nBefore=containers.target podman.service\n",
            "name": "10-before-containers.conf"
          }
        ],
        "enabled": true,
        "name": "firewalld.service"
      },
      {
        "contents": "[Unit]\nDescription=Apply declarative firewalld rules\nAfter=firewalld.service network.target\nWants=firewalld.service\nConditionPathExists=!/var/lib/.firewalld-configured\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\n# Ensure we start from the zone file we laid down\nExecStart=firewall-cmd --reload\n# HTTPS + HTTP for Caddy (TLS termination + ACME HTTP-01)\nExecStart=firewall-cmd --permanent --add-service=https\nExecStart=firewall-cmd --permanent --add-service=http\n# QUIC / HTTP3\nExecStart=firewall-cmd --permanent --add-port=443/udp\n# STUN (Netbird / TURN discovery)\nExecStart=firewall-cmd --permanent --add-port=3478/udp\n# TURN relay port range\nExecStart=firewall-cmd --permanent --add-port=49152-65535/udp\n# SSH (keep this unless you want lockout)\nExecStart=firewall-cmd --permanent --add-service=ssh\n# Apply permanent rules to runtime\nExecStart=firewall-cmd --reload\nExecStart=/bin/touch /var/lib/.firewalld-configured\nStandardOutput=journal\nStandardError=journal\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "firewalld-configure.service"
      },
      {
        "contents": "[Unit]\nDescription=Derive a stable hostname from hardware identifiers\nConditionPathExists=!/var/lib/.hostname-derived\nAfter=local-fs.target\nBefore=coreos-tpm-enroll.service\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/bash -lc '\n  UUID=$(cat /sys/class/dmi/id/product_uuid 2\u003e/dev/null || cat /etc/machine-id) \u0026\u0026 \\\n  HASH=$(echo -n \"$UUID\" | sha256sum | cut -c1-3) \u0026\u0026 \\\n  /usr/bin/hostnamectl set-hostname $HASH'\nExecStartPost=/usr/bin/touch /var/lib/.hostname-derived\nStandardOutput=journal\nStandardError=journal\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "random-hostname.service"
      },
      {
        "contents": "[Unit]\nDescription=Enroll LUKS+TPM2 and seal age key via systemd-creds\nConditionPathExists=!/var/lib/.tpm-enrolled\nAfter=local-fs.target random-hostname.service\nBefore=tpm-unseal-age.service\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/usr/local/bin/tpm-enroll.sh\nStandardOutput=journal\nStandardError=journal\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "coreos-tpm-enroll.service"
      },
      {
        "contents": "[Unit]\nDescription=Unseal age identity key via TPM2 (systemd-creds)\nAfter=local-fs.target coreos-tpm-enroll.service\nConditionPathExists=/etc/age/%h.identity.secure\nBefore=gitops-sync.service\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/usr/bin/systemd-creds decrypt \\\n  /etc/age/%h.identity.secure \\\n  /run/age.key\nExecStartPost=/usr/bin/chmod 0400 /run/age.key\nStandardOutput=journal\nStandardError=journal\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "tpm-unseal-age.service"
      },
      {
        "contents": "[Unit]\nDescription=Install sops binary\nConditionPathExists=!/usr/local/bin/sops\nAfter=network-online.target\nWants=network-online.target\nBefore=gitops-sync.service\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nEnvironment=SOPS_VERSION=v3.9.4\nExecStart=/bin/bash -c '\\\n  curl -sSfL \\\n    \"https://github.com/getsops/sops/releases/download/${SOPS_VERSION}/sops-${SOPS_VERSION}.linux.amd64\" \\\n    -o /usr/local/bin/sops \u0026\u0026 \\\n  chmod +x /usr/local/bin/sops \u0026\u0026 \\\n  echo \"sops ${SOPS_VERSION} installed\"'\nStandardOutput=journal\nStandardError=journal\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-sops.service"
      },
      {
        "contents": "[Unit]\nDescription=GitOps: sync quadlets, secrets, caddy, firewalld from git\n# tpm-unseal-age places /run/age.key before this runs\nAfter=network-online.target tpm-unseal-age.service install-sops.service\nWants=network-online.target\nRequires=tpm-unseal-age.service install-sops.service\n\n[Service]\nType=oneshot\nEnvironmentFile=/etc/gitops.env\nExecStart=/opt/gitops/sync.sh\nStandardOutput=journal\nStandardError=journal\n",
        "name": "gitops-sync.service"
      },
      {
        "contents": "[Unit]\nDescription=GitOps sync every 5 minutes\n\n[Timer]\nOnBootSec=2min\nOnUnitActiveSec=5min\nRandomizedDelaySec=30\nPersistent=true\n\n[Install]\nWantedBy=timers.target\n",
        "enabled": true,
        "name": "gitops-sync.timer"
      }
    ]
  }
}
