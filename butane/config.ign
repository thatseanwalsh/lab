        "contents": {
          "compression": "gzip",
          "source": "data:;base64,H4sIAAAAAAAC/2TOPU7EMBBH8X5OkQMENoKCys0qDcWKBpQiSmHZf7OWnBnLM0aE0yPxUW39pKff+sbZNpqhoeVqWdjZXpMOSdrQOlveMShCgynNSL4Xm1HBERwy1LHQGUkaXJHgy13Se/PtHUa0XqSzbbRcvf1eabmiwZ1a59P/9PWo+KsvPwB1u0S46WmaRs1fcI8Pl5El4mNk0Z7jyIJPBKL1mdV8KRstng3xfNwgvgMAAP//0VHjpuAAAAA="
