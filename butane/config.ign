        "path": "/usr/local/bin/tpm-enroll.sh",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 488
      },
      {
        "path": "/etc/sysctl.d/99-hardening.conf",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,H4sIAAAAAAAC/3TMQQpCMQyE4X1P0RMEFXH3zlJK3lRKYxvSKHh7QQTrwvU383c4VX2ciUcvlEXINJUqDotbPIZf31HyXfzfxlnTfHYeo1XM1S7ffmaGerIct3gIDdYhtN8wr8kw3Sr7+/mRpm4rnMIrAAD//3+KoauzAAAA"
