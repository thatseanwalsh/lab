# /etc/containers/systemd/netbird-signal.container
# Quadlet unit for the Netbird signal server

[Unit]
Description=Netbird Signal Server
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/netbirdio/signal:latest
PublishPort=127.0.0.1:10000:10000
Network=caddy-net.network
NoNewPrivileges=true
DropCapability=ALL

[Service]
Exec=--port 10000 --log-level info --disable-anonymous-metric
Restart=always
RestartSec=10s

[Install]
WantedBy=default.target
