[Unit]
Description=Zitadel Identity Provider
After=network-online.target zitadel-db.service
Wants=network-online.target
Requires=zitadel-db.service caddy-net.network zitadel-db.volume zitadel-certs.volume

[Container]
Image=ghcr.io/zitadel/zitadel:latest
Network=caddy-net.network

EnvironmentFile=/run/user/1000/secrets/zitadel.env

Environment=ZITADEL_EXTERNALDOMAIN=id.zehru.com
Environment=ZITADEL_EXTERNALPORT=443
Environment=ZITADEL_EXTERNALSECURE=true
Environment=ZITADEL_TLS_ENABLED=false
Environment=ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=admin
Environment=ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD_CHANGEDREQUIRED=false

PublishPort=127.0.0.1:8082:8080

Volume=/etc/zitadel/config.yaml:/etc/zitadel/config.yaml:ro
Exec=start --tlsMode external --masterkeyFromEnv --config /etc/zitadel/config.yaml

NoNewPrivileges=true
DropCapability=ALL

HealthCmd=wget -qO- http://localhost:8080/debug/ready || exit 1
HealthInterval=30s
HealthTimeout=10s
HealthRetries=5

[Service]
Restart=always
RestartSec=10s
TimeoutStartSec=180

[Install]
WantedBy=default.target